```elixir
alias Colorex.HSL

width = 20
height = 10
frames = 120

data =
  for x <- 0..width, y <- 0..height, f <- 1..frames do
    dx = x - width / 2
    dy = y - height / 2
    d = :math.sqrt(:math.pow(dx, 2) + :math.pow(dy, 2))

    %{
      x: x,
      y: y,
      color: if(d * f == 0, do: 1, else: :math.sin(10 * f / 3 / frames * d + 2) / d),
      frame: f
    }
  end

plot_size = 240

Vl.new(
  title: "Animated Sinc Wave",
  height: plot_size,
  width: plot_size * width / height,
  config: [legend: [gradient_length: plot_size]]
)
|> Vl.data_from_values(data)
|> Vl.mark(:rect)
|> Vl.encode(:x, field: :x, type: :ordinal, axis: nil)
|> Vl.encode(:y, field: :y, type: :ordinal, axis: nil)
|> Vl.encode(:color,
  field: :color,
  type: :quantitative,
  scale: %{
    domain: [-1, 1],
    scheme: [expr: "col"]
  },
  legend: %{
    height: 400,
    orient: :right,
    title: nil,
    offset: 10,
    padding: 0,
    titleFontSize: 30,
    labelFontSize: 20
  }
)
|> Vl.param("frame", value: 1, bind: [name: "Frame", input: :range, min: 1, max: frames, step: 1])
|> Vl.param("col",
  value: :blues,
  bind: [name: "Color Scheme", input: :select, options: color_schemes]
)
|> Vl.transform(filter: "datum.frame == frame")
```

```elixir
rad = 12
dx = Nx.iota({rad * 2, 1}) |> Nx.subtract(rad) |> Nx.divide(rad)
dy = Nx.iota({1, rad * 2}) |> Nx.subtract(rad) |> Nx.divide(rad)
dx2 = Nx.pow(dx, 2)
dy2 = Nx.pow(dy, 2)
rad = Nx.add(dx2, dy2) |> Nx.sqrt()
angle = Nx.atan2(dy, dx)

freq =
  Nx.iota({70, 1, 1})
  |> Nx.divide(10)
  |> Nx.multiply(:math.pi())

freq_sqrt = Nx.sqrt(freq)

img =
  rad
  |> Nx.multiply(freq_sqrt)
  |> Nx.add(angle)
  |> Nx.subtract(freq)
  |> Nx.sin()

imgData =
  Nx.to_list(img)
  |> Enum.with_index()
  |> Enum.flat_map(fn {frame, fi} ->
    frame
    |> Enum.with_index()
    |> Enum.flat_map(fn
      {row, ri} ->
        Enum.with_index(row)
        |> Enum.map(fn {v, ci} ->
          %{x: ci, y: ri, color: v, frame: fi + 1}
        end)
    end)
  end)

plot_size = 360

plot1 =
  Vl.new(width: plot_size, height: plot_size, title: "Dynamic Frame")
  |> Vl.data_from_values(imgData)
  |> Vl.mark(:rect)
  |> Vl.encode(:x, field: :x, type: :ordinal, axis: nil)
  |> Vl.encode(:y, field: :y, type: :ordinal, axis: nil)
  |> Vl.encode(:color,
    field: :color,
    type: :quantitative,
    scale: %{
      domain: [-1, 1],
      scheme: [expr: "col"]
    },
    legend: %{
      orient: :right,
      title: nil,
      offset: 10,
      padding: 0,
      titleFontSize: 30,
      labelFontSize: 20
    }
  )
  |> Vl.transform(filter: "datum.frame == frame")

plot2 =
  Vl.new(width: plot_size, height: plot_size, title: "Static Frame")
  |> Vl.data_from_values(imgData)
  |> Vl.mark(:rect)
  |> Vl.encode(:x, field: :x, type: :ordinal, axis: nil)
  |> Vl.encode(:y, field: :y, type: :ordinal, axis: nil)
  |> Vl.encode(:color,
    field: :color,
    type: :quantitative,
    scale: %{
      domain: [-1, 1],
      scheme: "greys"
    },
    legend: %{
      orient: :right,
      title: nil,
      offset: 10,
      padding: 0,
      titleFontSize: 30,
      labelFontSize: 20
    }
  )
  |> Vl.transform(filter: "datum.frame == 30")

combined_plot =
  Vl.new(
    title: "Two images side by side",
    config: [legend: [gradient_length: plot_size]]
  )
  |> Vl.concat([plot1, plot2])
  |> Vl.param("frame",
    value: 1,
    bind: [name: "Frame", input: :range, min: 1, max: elem(Nx.shape(img), 0), step: 1]
  )
  |> Vl.param("col",
    value: :viridis,
    bind: [name: "Color Scheme", input: :select, options: color_schemes]
  )
  |> Vl.resolve(:scale, color: :independent, stroke: :independent, fill: :independent)
```

```elixir
defmodule TensorPlot do
  @color_schemes [
    :accent,
    :category10,
    :category20,
    :category20b,
    :category20c,
    :observable10,
    :dark2,
    :paired,
    :pastel1,
    :pastel2,
    :set1,
    :set2,
    :set3,
    :tableau10,
    :tableau20,
    :blues,
    :tealblues,
    :teals,
    :greens,
    :browns,
    :oranges,
    :reds,
    :purples,
    :warmgreys,
    :greys,
    :viridis,
    :magma,
    :inferno,
    :plasma,
    :cividis,
    :turbo,
    :bluegreen,
    :bluepurple,
    :goldgreen,
    :goldorange,
    :goldred,
    :greenblue,
    :orangered,
    :purplebluegreen,
    :purpleblue,
    :purplered,
    :redpurple,
    :yellowgreenblue,
    :yellowgreen,
    :yelloworangebrown,
    :yelloworangered,
    :darkblue,
    :darkgold,
    :darkgreen,
    :darkmulti,
    :darkred,
    :lightgreyred,
    :lightgreyteal,
    :lightmulti,
    :lightorange,
    :lighttealblue,
    :blueorange,
    :brownbluegreen,
    :purplegreen,
    :pinkyellowgreen,
    :purpleorange,
    :redblue,
    :redgrey,
    :redyellowblue,
    :redyellowgreen,
    :spectral,
    :rainbow,
    :sinebow
  ]

  def plot(tensors, args \\ [])

  def plot(tensor = %Nx.Tensor{}, args) do
    plot([tensor], args)
  end

  def plot(tensors = [_h | _t], args) do
    plot_size = Keyword.get(args, :size, 300)

    tensors =
      for t <- tensors do
        {frames, channels, width, height} =
          case Nx.shape(t) do
            {f, 1, w, h} -> {f, 1, w, h}
            {f, 3, w, h} -> {f, 3, w, h}
            {1, w, h} -> {1, 1, w, h}
            {3, w, h} -> {1, 3, w, h}
            {f, w, h} -> {f, 1, w, h}
            {w, h} -> {1, 1, w, h}
          end

        Nx.reshape(t, {frames, channels, width, height})
      end

    max_frame = Enum.map(tensors, &elem(Nx.shape(&1), 0)) |> Enum.max()

    plots =
      for {t, ti} <- tensors |> Enum.with_index() do
        {frames, channels, _width, _height} = Nx.shape(t)
        {enc, _bits} = Nx.type(t)
        multiplier = if(enc == :f, do: 255, else: 1)

        imgData =
          t
          |> Nx.transpose(axes: [0, 2, 3, 1])
          |> Nx.to_list()
          |> Enum.with_index()
          |> Enum.flat_map(fn {frame, fi} ->
            frame
            |> Enum.with_index()
            |> Enum.flat_map(fn
              {row, ri} ->
                Enum.with_index(row)
                |> Enum.map(fn
                  {[r, g, b | _alpha], ci} ->
                    %{
                      x: ci,
                      y: ri,
                      color:
                        %Colorex.RGB{
                          red: r * multiplier,
                          green: g * multiplier,
                          blue: b * multiplier
                        }
                        |> to_string(),
                      frame: fi + 1,
                      last_frame: fi + 1 == frames
                    }

                  {v, ci} ->
                    %{
                      x: ci,
                      y: ri,
                      color: v,
                      frame: fi + 1,
                      last_frame: fi + 1 == frames
                    }
                end)
            end)
          end)

        plot =
          Vl.new(
            width: plot_size,
            height: plot_size,
            title: Keyword.get(args, :labels, []) |> Enum.at(ti, "Image #{ti + 1}")
          )
          |> Vl.data_from_values(imgData)
          |> Vl.mark(:rect)
          |> Vl.encode(:x, field: :x, type: :ordinal, axis: nil)
          |> Vl.encode(:y, field: :y, type: :ordinal, axis: nil)
          |> Vl.transform(
            filter: "datum.frame == frame || (datum.frame < frame && datum.last_frame)"
          )

        case channels do
          3 ->
            plot |> Vl.encode(:color, field: :color, type: :nominal, scale: nil)

          1 ->
            plot
            |> Vl.encode(:color,
              field: :color,
              type: :quantitative,
              scale: %{
                domain: [
                  Nx.round(Nx.reduce_min(t)) |> Nx.to_number(),
                  Nx.round(Nx.reduce_max(t)) |> Nx.to_number()
                ],
                scheme: [expr: "col"]
              },
              legend: %{
                orient: :right,
                title: nil,
                offset: 10,
                padding: 0,
                titleFontSize: 30,
                labelFontSize: 20
              }
            )
        end
      end

    Vl.new(
      title: Keyword.get(args, :titel, "Images"),
      config: [legend: [gradient_length: plot_size]],
      columns: Keyword.get(args, :columns, nil)
    )
    |> Vl.concat(plots, Keyword.get(args, :concat, :wrappable))
    |> Vl.param("frame",
      value: 1,
      bind: if(max_frame > 1, do: [name: "Frame", input: :range, min: 1, max: max_frame, step: 1])
    )
    |> Vl.param("col",
      value: Keyword.get(args, :cmap, :viridis),
      bind:
        Keyword.get(args, :cmaps, @color_schemes)
        |> case do
          [f | _] = opts ->
            cmap = Keyword.get(args, :cmap, f)
            [
              name: "Color Scheme",
              input: :select,
              options: [cmap | opts |> Enum.reject(&(to_string(&1) == to_string(cmap)))]
            ]

          _ ->
            nil
        end
    )
    |> Vl.resolve(:scale, color: :independent, stroke: :independent, fill: :independent)
  end
end

Kino.nothing()
```

```elixir
defmodule Swirl do
  import Nx.Defn

  # defn expects non-tensor args to be passed as arg list
  defn gen(opts \\ []) do
    # make Nx.sqrt() and Nx.sin() available without namespace
    import Nx

    # we need to use Nx.Constants.pi instead of :math.pi() inside defn
    import Nx.Constants, only: [pi: 0]

    opts = keyword!(opts, rad: 6, frames: 10, freq: 10, phase: 0)
    rad = opts[:rad]
    freq = opts[:freq]
    frames = opts[:frames]
    phase = opts[:phase]

    # tensor calculations can be done with operators inside defn
    dx = iota({rad * 2, 1}) / rad - 1
    dy = iota({1, rad * 2}) / rad - 1
    dx2 = dx ** 2
    dy2 = dy ** 2
    rad = sqrt(dx2 + dy2)
    angle = atan2(dy, dx)

    freqs =
      (iota({frames, 1, 1}) / frames + phase) * 2 * pi() * freq

    cos(sqrt(freqs) * rad + angle - freqs)
  end
end

rad = 12
dx = Nx.iota({rad * 2, 1}) |> Nx.subtract(rad) |> Nx.divide(rad)
dy = Nx.iota({1, rad * 2}) |> Nx.subtract(rad) |> Nx.divide(rad)
dx2 = Nx.pow(dx, 2)
dy2 = Nx.pow(dy, 2)
radius = Nx.add(dx2, dy2) |> Nx.sqrt()
angle = Nx.atan2(dy, dx)

swirl = Swirl.gen(rad: rad, frames: 60, freq: 1, phase: 0)

colored =
  Nx.stack(for(d <- 0..2, do: Swirl.gen(rad: rad, frames: 1, freq: 4 * d, phase: 0.5)), axis: 1)
  |> Nx.add(1)
  |> Nx.divide(2)

tornado =
  Nx.stack(
    for(d <- 0..2, do: Swirl.gen(rad: rad, frames: 60, freq: 1, phase: 0.2 * d)),
    axis: 1
  )

Kino.nothing()
```

```elixir
[swirl, radius, angle, colored, tornado]
|> TensorPlot.plot(
  concat: :wrappable,
  columns: 3,
  cmap: :viridis,
  cmaps: ["viridis", "blues", "greys"],
  size: 215,
  titel: "Composition of a Swirl",
  labels: ["Swirl", "Radius", "Angle", "Colored Swirl", "RGB Tornado"]
)
```

```elixir
res = 16

kx =
  Nx.iota({res, res, 1, res, res}, axis: 0)
  |> Nx.reshape({res * res, 1, res, res})

ky =
  Nx.iota({res, res, 1, res, res}, axis: 1)
  |> Nx.reshape({res * res, 1, res, res})
  |> Nx.multiply(kx)
  |> Nx.remainder(res)

x = Nx.iota({res * res, 1, res, res}, axis: 2)
y = Nx.iota({res * res, 1, res, res}, axis: 3)

a =
  Nx.multiply(x, kx)
  |> Nx.add(Nx.multiply(y, ky))
  |> Nx.divide(res)
  |> Nx.multiply(2 * :math.pi())

basis_x = a |> Nx.cos()
basis_y = a |> Nx.sin()

[x, y, basis_x, basis_y]
|> TensorPlot.plot(
  concat: :wrappable,
  columns: 3,
  cmap: :viridis,
  cmaps: ["viridis", "blues", "greys"],
  size: 215,
  titel: "Composition of a Swirl",
  labels: ["Freq", "X", "Y", "Cos", "Sin"]
)
```
