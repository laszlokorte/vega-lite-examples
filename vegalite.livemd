```elixir
alias VegaLite, as: Vl

x_values = Nx.linspace(0, 10, n: 100)
sin_values = Nx.sin(x_values) |> Nx.multiply(100)
cos_values = Nx.cos(x_values) |> Nx.multiply(50)

sin_data =
  Enum.zip_with(
    Nx.to_flat_list(x_values),
    Nx.to_flat_list(sin_values),
    &%{x: &1, y: &2, series: :sin}
  )

cos_data =
  Enum.zip_with(
    Nx.to_flat_list(x_values),
    Nx.to_flat_list(cos_values),
    &%{x: &1, y: &2, series: :cos}
  )

Vl.new(width: 600, height: 400)
|> Vl.data_from_values(sin_data ++ cos_data)
|> Vl.mark(:line, color: :red, stroke_dash: [5, 2])
|> Vl.encode(:x, field: :x, type: :quantitative)
|> Vl.encode(:y, field: :y, type: :quantitative)
|> Vl.encode(:color,
  field: :series,
  type: :nominal,
  scale: %{domain: [:sin, :cos], range: ["red", "blue"]}
)
|> Vl.encode(:stroke_dash,
  field: :series,
  type: :nominal,
  scale: %{domain: [:sin, :cos], range: [[1, 0], [10, 5]]}
)
```

```elixir
alias VegaLite, as: Vl

# Example data
data = [
  %{category: "A", series: "S1", value: 5},
  %{category: "A", series: "S2", value: 3},
  %{category: "B", series: "S1", value: 6},
  %{category: "B", series: "S2", value: 2}
]

Vl.new(width: 400, height: 300)
|> Vl.data_from_values(data)
|> Vl.mark(:bar)
# main category
|> Vl.encode(:x, field: :category, type: :nominal)
# series offset → bars next to each other
|> Vl.encode(:x_offset, field: :series)
# height
|> Vl.encode(:y, field: :value, type: :quantitative)
# color by series
|> Vl.encode(:color, field: :series)
```

```elixir
Vl.new()
|> Vl.data_from_url("https://vega.github.io/editor/data/cars.json")
|> Vl.param("size",
  value: 20,
  bind: [name: "Dot Size", input: :range, min: 100, max: 1000, step: 10]
)
|> Vl.param("mpg", value: 0, bind: [name: "min M/G", input: :range, min: 0, max: 200, step: 1])
|> Vl.param("ps", value: 0, bind: [name: "min PS", input: :range, min: 0, max: 200, step: 1])
|> Vl.param("color", value: "red", bind: [name: "Dot Color", input: :color])
|> Vl.mark(:circle, size: [expr: "size"], color: [expr: "color"])
|> Vl.encode_field(:x, "Horsepower",
  selection: [expr: "choice"],
  type: :quantitative,
  scale: [domain: [0, 300]]
)
|> Vl.encode_field(:y, "Miles_per_Gallon", type: :quantitative, scale: [domain: [0, 50]])
|> Vl.transform(filter: "datum.Miles_per_Gallon > mpg")
|> Vl.transform(filter: "datum.Horsepower > ps")
